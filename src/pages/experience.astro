---
import Layout from '../layouts/Layout.astro';
import { experience } from '../data/site';
---

<Layout title="Experience | T. Hareshjaa Pillay">
	<div class="page-shell">
		<header class="site-header reveal">
			<a href="/" class="brand">
				T. Hareshjaa Pillay
				<small>AI Portfolio Interface</small>
			</a>
			<nav>
				<a href="/">Home</a>
				<a href="/projects">Projects</a>
				<a href="/work-experience">Work Experience</a>
				<a href="/education">Education</a>
				<a href="/contact">Contact</a>
			</nav>
		</header>

		<main class="page-main">
			<section class="card reveal stagger-1">
				<p class="chips">This page is kept for compatibility. Visit the dedicated work experience page for the latest version.</p>
				<a href="/work-experience">Go to Work Experience</a>
			</section>

			<section class="panel reveal stagger-1">
				<p class="eyebrow">Professional signal</p>
				<h1>Experience</h1>
				<p class="lead">{experience.department} within a {experience.companyType} environment.</p>
				<div class="meta-list">
					<span class="meta-chip">{experience.duration}</span>
				</div>
			</section>

			<section class="story-layout reveal stagger-2">
				<article class="card">
					<h2>Work Performed</h2>
					<ul class="timeline">
						{experience.workPerformed.map((task) => <li>{task}</li>)}
					</ul>
				</article>

				<article class="card">
					<h2>Tools Used</h2>
					<ul class="plain-list">
						{experience.toolsUsed.map((tool) => <li>{tool}</li>)}
					</ul>
				</article>
			</section>
		</main>
	</div>
</Layout>
