---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { education, profile, workExperience } from '../data/site';

const projectFlow = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="T. Hareshjaa Pillay | Home">
	<div class="page-shell">
		<header class="site-header reveal">
			<a href="/" class="brand">
				T. Hareshjaa Pillay
				<small>AI Portfolio Interface</small>
			</a>
			<nav>
				<a href="/" aria-current="page">Home</a>
				<a href="/projects">Projects</a>
				<a href="/work-experience">Work Experience</a>
				<a href="/education">Education</a>
				<a href="/contact">Contact</a>
			</nav>
		</header>

		<main class="page-main scroll-flow">
			<section class="panel step-section reveal stagger-1">
				<p class="eyebrow">Step 1 / About me</p>
				<h1>{profile.name}</h1>
				<p class="lead">Highly motivated Bachelor of Science in Artificial Intelligence applicant with strong initiative, leadership experience, and a clear mission to build useful AI products that improve daily life.</p>
				<div class="stack-copy">
					{profile.bio.map((line) => <p class="chips">{line}</p>)}
					<p class="chips"><strong>Why AI:</strong> {profile.aiMotivation}</p>
				</div>
				<div class="meta-list">
					<span class="meta-chip">Problem Solver</span>
					<span class="meta-chip">Fast Learner</span>
					<span class="meta-chip">Team Player</span>
					<span class="meta-chip">Delivery Focused</span>
				</div>
				<div class="meta-list">
					<span class="meta-chip">{profile.location}</span>
					<a class="meta-chip" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
					<a class="meta-chip" href={`mailto:${profile.workEmail}`}>Work Email</a>
					<a class="meta-chip" href={`mailto:${profile.personalEmail}`}>Personal Email</a>
				</div>
			</section>

			<section class="panel step-section reveal">
				<p class="eyebrow">Step 2 / Personal journey</p>
				<h2>How I Chose Artificial Intelligence</h2>
				<div class="stack-copy">
					{profile.careerJourney.map((line) => <p class="chips">{line}</p>)}
				</div>
			</section>

			<section class="panel step-section reveal">
				<p class="eyebrow">Step 3 / Education</p>
				<h2>{education.aLevels.school}</h2>
				<p class="chips">A Levels in Mathematics, Chemistry, and Physics.</p>
				<p class="chips">Detailed grades are available on the Education page.</p>
				<p class="chips">IELTS: {education.ielts}</p>
				<a href="/education">View full education details</a>
			</section>

			<section class="panel step-section reveal">
				<p class="eyebrow">Step 4 / Leadership, service, and achievements</p>
				<h2>Leadership, Service, and Achievements</h2>
				<ul class="timeline compact-list">
					{profile.extracurriculars.map((item) => <li><strong>{item.title}</strong> - {item.duration}<br />{item.description}</li>)}
				</ul>
			</section>

			<section class="panel step-section reveal">
				<p class="eyebrow">Step 5 / Experience</p>
				<h2>Work Experience</h2>
				<ul class="timeline compact-list">
					{
						workExperience.map((item) => (
							<li>
								<strong>{item.role}</strong> - {item.organization} ({item.period})
								<br />
								{item.description}
							</li>
						))
					}
				</ul>
				<a href="/work-experience">View full work experience</a>
			</section>

			{
				projectFlow.map((project, index) => (
					<section class="panel step-section reveal" style={`--reveal-delay: ${index * 70}ms`}>
						<p class="eyebrow">Step {index + 6} / Project {index + 1}</p>
						<h2>{project.data.title}</h2>
						<p class="lead">{project.data.summary}</p>
						<p class="chips"><strong>Problem:</strong> {project.data.problem}</p>
						<p class="chips"><strong>Solution:</strong> {project.data.solution}</p>
						<p class="chips"><strong>Impact:</strong> {project.data.impact}</p>
						<p class="chips"><strong>Your role:</strong> {project.data.contributions}</p>
						<p class="chips">{project.data.technologies.join(' · ')}</p>
						{project.data.github && (
							<a href={project.data.github} target="_blank" rel="noreferrer" class="meta-chip border-chip" style="display: inline-block; margin-top: 1rem;">View Repository on GitHub ↗</a>
						)}
					</section>
				))
			}

			<section class="panel step-section reveal">
				<p class="eyebrow">Final step / Contact</p>
				<h2>Let's build something useful</h2>
				<div class="meta-list">
					<a class="meta-chip" href={`mailto:${profile.workEmail}`}>Work: {profile.workEmail}</a>
					<a class="meta-chip" href={`mailto:${profile.personalEmail}`}>Personal: {profile.personalEmail}</a>
					<a class="meta-chip" href={profile.github} target="_blank" rel="noreferrer">GitHub</a>
				</div>
				<a href="/contact">Open contact page</a>
			</section>
		</main>

		<footer class="site-footer">
			<div class="footer-inner">
				<strong>{profile.name}</strong>
				<a href={`mailto:${profile.workEmail}`}>Work: {profile.workEmail}</a>
				<a href={`mailto:${profile.personalEmail}`}>Personal: {profile.personalEmail}</a>
				<span>{profile.phone}</span>
			</div>
		</footer>
	</div>
</Layout>
