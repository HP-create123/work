---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'T. Hareshjaa Pillay | Portfolio',
	description = 'Aspiring AI developer building tools that simplify data analysis and automate real-world workflows.'
} = Astro.props;

const shapes = [
	// 1. Robotics / Robot Head
	`<rect x="62" y="54" width="96" height="84" rx="14" /><circle cx="94" cy="90" r="9" /><circle cx="126" cy="90" r="9" /><path d="M84 116h52M110 54V34" />`,
	// 2. Technology / Circuit Board
	`<rect x="24" y="24" width="232" height="132" rx="14" /><path d="M42 52h86M42 84h132M42 116h76M168 52h70M188 116h50" />`,
	// 3. Technology / Server Rack
	`<rect x="40" y="40" width="180" height="40" rx="8" /><rect x="40" y="110" width="180" height="40" rx="8" /><rect x="40" y="180" width="180" height="40" rx="8" /><circle cx="190" cy="60" r="6" /><circle cx="190" cy="130" r="6" /><circle cx="190" cy="200" r="6" />`,
	// 4. Technology / Drone
	`<circle cx="60" cy="60" r="30" /><circle cx="200" cy="60" r="30" /><circle cx="60" cy="200" r="30" /><circle cx="200" cy="200" r="30" /><rect x="90" y="90" width="80" height="80" rx="10" /><path d="M80 80l-20-20M180 80l20-20M80 180l-20 20M180 180l20 20" />`,
	// 5. Island / Mountains
	`<ellipse cx="130" cy="180" rx="100" ry="30" /><path d="M60 180l40-80 30 30 50-60 40 110" />`,
	// 6. Island / Palm Tree
	`<path d="M130 220V120M130 130c-40-20-60-50-60-80M130 130c40-20 60-50 60-80M130 150c-40 0-70-10-80-30M130 150c40 0 70-10 80-30" />`,
	// 7. Education / Atom Science
	`<ellipse cx="130" cy="130" rx="90" ry="30" transform="rotate(30 130 130)" /><ellipse cx="130" cy="130" rx="90" ry="30" transform="rotate(150 130 130)" /><circle cx="130" cy="130" r="16" />`,
	// 8. Education / Graduation Cap
	`<path d="M30 100l100-40 100 40-100 40z" /><path d="M70 116v40c0 20 60 30 60 30s60-10 60-30v-40" /><path d="M220 100v60" />`,
	// 9. Education / Open Book
	`<path d="M130 60v120c-30-10-60-10-90 0V60c30-10 60-10 90 0z" /><path d="M130 60v120c30-10 60-10 90 0V60c-30-10-60-10-90 0z" /><path d="M60 90h50M60 120h50M150 90h50M150 120h50" />`
];

const rows = 4;
const cols = 5; // 20 giant scattered shapes
const bgElements = [];
let idx = 0;
for (let r = 0; r < rows; r++) {
	for (let c = 0; c < cols; c++) {
		const shape = shapes[idx % shapes.length];
		// Mathematically isolate each shape to its own sector of the screen to explicitly prevent overlap
		const top = (r / rows) * 100 + (Math.random() * 8); 
		const left = (c / cols) * 100 + (Math.random() * 8); 
		
		const size = Math.floor(Math.random() * 80) + 160; // 160 to 240px
		const rot = Math.floor(Math.random() * 360);
		const delay = (Math.random() * 6).toFixed(2);
		const opac = (Math.random() * 0.3 + 0.35).toFixed(2); // Light theme needs stronger opaque bounding mapping
		
		bgElements.push({ shape, top, left, size, rot, delay, opac });
		idx++;
	}
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Sora:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<div class="tech-atmosphere" aria-hidden="true">
			{bgElements.map((el) => (
				<svg 
					class="bg-icon" 
					style={`top: ${el.top}%; left: ${el.left}%; width: ${el.size}px; --base-rotation: ${el.rot}deg; animation-delay: ${el.delay}s; opacity: ${el.opac}; position: absolute; stroke: #167fd8; stroke-width: 4; stroke-linecap: round; stroke-linejoin: round;`} 
					viewBox="0 0 260 260" 
					fill="none" 
					set:html={el.shape} 
				/>
			))}
		</div>
		<slot />
		<script is:inline>
			const initScrollReveal = () => {
				const revealItems = Array.from(document.querySelectorAll('.reveal'));
				if (!revealItems.length) return;

				const observer = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add('is-visible');
								observer.unobserve(entry.target);
							}
						}
					},
					{ threshold: 0.2, rootMargin: '0px 0px -8% 0px' }
				);

				revealItems.forEach((item) => observer.observe(item));
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initScrollReveal, { once: true });
			} else {
				initScrollReveal();
			}
		</script>
	</body>
</html>
